{
  "name": "notes-app",
  "version": "1.0.0",
  "description": "Full-stack notes app with React frontend and Express backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server": "nodemon server.js",
    "client": "cd client && npm run dev",
    "dev": "start /B npm run server && cd client && npm run dev",
    "build": "cd client && npm run build",
    "prod": "npm run build && npm start"
  },
  "dependencies": {
    "express": "^4.21.0",
    "sql.js": "^1.11.0",
    "bcryptjs": "^2.4.3",
    "express-session": "^1.18.1",
    "dotenv": "^16.4.7",
    "helmet": "^8.0.0",
    "express-rate-limit": "^7.5.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
